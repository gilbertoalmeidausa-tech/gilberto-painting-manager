# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/painting_manager

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-use-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-use-another-openssl-rand-base64-48

# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# On Railway: set both to your Railway app domain, e.g. https://app.up.railway.app
CLIENT_URL=http://localhost:5173

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...

# ─── Email (team invites) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gilbertopropainting.com

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
TRIAL_DAYS=14

# ─── Railway deployment notes ────────────────────────────────────────────────
# Required in Railway dashboard (Variables tab):
#   DATABASE_URL      — from Railway PostgreSQL plugin (auto-populated)
#   JWT_ACCESS_SECRET — openssl rand -base64 48
#   JWT_REFRESH_SECRET — openssl rand -base64 48
#   NODE_ENV          — production
#   CLIENT_URL        — https://<your-app>.up.railway.app
#   APP_URL           — https://<your-app>.up.railway.app
#
# For file upload persistence, add a Railway Volume mounted at /app/uploads
